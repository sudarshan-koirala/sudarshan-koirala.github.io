---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllPosts } from '../../data/posts';

const posts = await getAllPosts();
const categories = ['All', ...Array.from(new Set(posts.map((p) => p.category)))];
---

<Base title="Blog" description="Articles about AI, Data Science, LLMs, Databricks, and developer tools by Sudarshan Koirala.">
  <div class="container-wide">
    <div class="page-header">
      <h1>Blog</h1>
      <p>
        Writing on AI engineering, data science, LLMs, and the tools I use every day —
        here and on <a href="https://medium.com/@sudarshan-koirala" target="_blank" rel="noopener">Medium</a>.
      </p>
    </div>

    <div class="filter-bar" role="tablist">
      {categories.map((cat, i) => (
        <button class:list={['filter-chip', { 'is-active': i === 0 }]} data-filter={cat}>
          {cat}
        </button>
      ))}
    </div>

    <div class="card-grid" id="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</Base>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLElement>('#post-grid .post-card');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.dataset.filter;
      chips.forEach((c) => c.classList.toggle('is-active', c === chip));
      cards.forEach((card) => {
        const show = filter === 'All' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
