---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getAllPosts } from '../data/posts';

const posts = (await getAllPosts()).slice(0, 6);
---

<Base title="Sudarshan Koirala — Senior GenAI Engineer & Content Creator">
  <!-- Hero -->
  <section class="hero">
    <div class="container-wide">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Sudarshan Koirala</h1>
          <p class="hero-tagline">
            Senior GenAI Engineer at <strong>KONE</strong>. I build enterprise AI solutions
            and teach data science, LLMs, and developer tools on
            <a href="https://www.youtube.com/@datasciencebasics" target="_blank" rel="noopener">YouTube</a>.
          </p>
          <div class="hero-links">
            <a href="https://www.youtube.com/@datasciencebasics" target="_blank" rel="noopener">▶ YouTube</a>
            <a href="https://www.linkedin.com/in/sudarshan-koirala/" target="_blank" rel="noopener">in LinkedIn</a>
            <a href="https://github.com/sudarshan-koirala" target="_blank" rel="noopener">⌘ GitHub</a>
            <a href="https://medium.com/@sudarshan-koirala" target="_blank" rel="noopener">✎ Medium</a>
            <a href="https://topmate.io/sudarshan_koirala" target="_blank" rel="noopener">💼 Consulting</a>
          </div>
        </div>
        <img src="/profile.jpg" alt="Sudarshan Koirala — Data Science Basics" class="hero-photo" width="160" height="160" />
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container-wide">
        <div class="section-head">
          <h2 class="section-title">Latest Articles</h2>
          <a href="/blog" class="section-link">View all →</a>
        </div>
        <div class="card-grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Featured YouTube -->
  <section class="section">
    <div class="container-wide">
      <div class="section-head">
        <h2 class="section-title">Featured Videos</h2>
        <a href="/videos" class="section-link">All videos →</a>
      </div>
      <div class="video-embed">
        <iframe
          src="https://www.youtube-nocookie.com/embed/videoseries?list=PLz-qytj7eIWWRz_1hFSleVBwZAoD1eTqU"
          title="Databricks Free Edition"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          loading="lazy"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-wide">
      <div class="cta-banner">
        <p><strong>Want to learn AI and Data Science the simple way?</strong><br/>
          Subscribe to Data Science Basics on YouTube — practical tutorials, no fluff.</p>
        <a href="https://www.youtube.com/@datasciencebasics?sub_confirmation=1" target="_blank" rel="noopener">
          Subscribe on YouTube
        </a>
      </div>
    </div>
  </section>
</Base>
