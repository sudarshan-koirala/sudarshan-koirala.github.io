---
import Base from '../layouts/Base.astro';
---

<Base title="Resume" description="Resume of Sudarshan Koirala, Senior GenAI Engineer at KONE and creator of Data Science Basics.">
  <div class="container document-container">
    <header class="document-header">
      <div>
        <p class="eyebrow">Resume</p>
        <h1>Sudarshan Koirala</h1>
        <p>Senior GenAI Engineer · Data Scientist · AI Educator</p>
      </div>
      <button class="print-link" type="button" onclick="window.print()">
        <span class="button-icon icon-print" aria-hidden="true"></span>
        <span>Print / Save PDF</span>
      </button>
    </header>

    <section class="document-note">
      <p>
        This resume is the concise version: best for recruiters, hiring managers, and consulting conversations.
        The CV is the longer record of education, public work, and technical focus areas.
      </p>
    </section>

    <section class="document-section">
      <h2>Contact</h2>
      <p>
        Espoo, Finland ·
        <a href="mailto:basicsdatascience@gmail.com">basicsdatascience@gmail.com</a> ·
        <a href="https://www.linkedin.com/in/sudarshan-koirala/" target="_blank" rel="noopener">LinkedIn</a> ·
        <a href="https://github.com/sudarshan-koirala" target="_blank" rel="noopener">GitHub</a> ·
        <a href="https://www.youtube.com/@datasciencebasics" target="_blank" rel="noopener">YouTube</a>
      </p>
    </section>

    <section class="document-section">
      <h2>Summary</h2>
      <p>
        Senior GenAI Engineer with experience across enterprise AI, machine learning, MLOps, cloud data
        platforms, and technical education. Builds production-oriented AI/ML solutions using LLMs, Python,
        Databricks, AWS, Azure OpenAI, and modern ML engineering practices.
      </p>
    </section>

    <section class="document-section">
      <h2>Experience</h2>

      <div class="document-item">
        <div class="document-item-head">
          <h3>KONE Oyj</h3>
          <span>2022 - Present · Espoo, Finland</span>
        </div>
        <p><strong>Senior GenAI Engineer</strong> · Current role</p>
        <ul>
          <li>Lead development of AI/ML-driven generative AI solutions for enterprise use cases.</li>
          <li>Design automated workflows for ML solutions and guide teams on MLOps best practices.</li>
          <li>Prototype and deliver LLM solutions using AWS Bedrock, Azure OpenAI, Databricks, and related platforms.</li>
          <li>Support SRE practices, reliability, and operational readiness for AI systems.</li>
        </ul>
        <p><strong>Data Scientist</strong> · Earlier KONE role</p>
        <ul>
          <li>Built data science and machine learning solutions before moving into the Senior GenAI Engineer role.</li>
          <li>Applied Python, SQL, cloud tooling, and ML workflows to industrial and enterprise data problems.</li>
        </ul>
      </div>

      <div class="document-item">
        <div class="document-item-head">
          <h3>Nokia Solutions and Networks Oyj</h3>
          <span>2020 - 2021</span>
        </div>
        <p><strong>Thesis Worker -> Machine Learning Trainee</strong></p>
        <ul>
          <li>Worked on NLP-based event discovery from social media feeds using spaCy and pre-trained models.</li>
          <li>Implemented end-to-end deep neural networks for tabular data.</li>
          <li>Served as scrum master for a team of 15 trainees.</li>
        </ul>
      </div>

      <div class="document-item">
        <div class="document-item-head">
          <h3>Data Science Basics</h3>
          <span>2022 - Present</span>
        </div>
        <p><strong>Content Creator</strong></p>
        <ul>
          <li>Create practical tutorials on AI, data science, Databricks, LLMs, and developer tools.</li>
          <li>Publish learning series covering Databricks, LangChain, LlamaIndex, AI coding tools, and agent workflows.</li>
        </ul>
      </div>
    </section>

    <section class="document-section">
      <h2>Education</h2>
      <div class="document-item compact">
        <h3>M.Sc. (Technology), Computer Science · Aalto University</h3>
        <p>2021 · Major: Big Data and Large-Scale Fundamentals · Minor: ML, DS & AI · GPA 5/5</p>
      </div>
      <div class="document-item compact">
        <h3>B.Eng., Software Engineering · Metropolia University of Applied Sciences</h3>
        <p>2018</p>
      </div>
      <div class="document-item compact">
        <h3>B.Sc., Physics · Tribhuvan University, Nepal</h3>
        <p>2010</p>
      </div>
    </section>

    <section class="document-section">
      <h2>Skills</h2>
      <p><strong>Languages:</strong> Python, SQL, PySpark, JavaScript</p>
      <p><strong>AI / ML / LLMs:</strong> LangChain, LlamaIndex, RAG, Azure OpenAI, Amazon Bedrock, PyTorch, MLflow, XGBoost</p>
      <p><strong>Data & Cloud:</strong> Databricks, AWS, Azure, Apache Spark, Docker, GitLab CI, Terraform</p>
      <p><strong>Tools:</strong> Claude Code, GitHub Copilot, KIRO, Git, Linux</p>
    </section>
  </div>
</Base>
